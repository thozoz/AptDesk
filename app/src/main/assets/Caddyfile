{
    admin off
}

:8080 {
    # Serve static dashboard files (extracted from Android APK assets)
    root * /opt/aptdesk/www
    file_server

    # Proxy full ttyd web interface
    handle_path /term/* {
        reverse_proxy 127.0.0.1:8081
    }

    # Proxy full noVNC web interface via websockify
    handle_path /vnc/* {
        reverse_proxy 127.0.0.1:5901
    }

    # Proxy Filebrowser app
    reverse_proxy /filesapp/* 127.0.0.1:8083

    # Proxy APIs directly to the Android Host (NanoHTTPd)
    reverse_proxy /api/* 127.0.0.1:8082
}
