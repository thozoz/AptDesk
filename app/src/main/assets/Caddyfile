:8080 {
    # Serve static dashboard files (extracted from Android APK assets)
    root * /opt/aptdesk/www
    file_server

    # Proxy terminal WebSocket to ttyd
    reverse_proxy /ws/term/* 127.0.0.1:8081

    # Proxy VNC WebSocket to websockify
    reverse_proxy /ws/vnc/* 127.0.0.1:5901

    # Proxy APIs directly to the Android Host (NanoHTTPd)
    # This handles Android status, file uploads/downloads (direct to host FS), and software installs
    reverse_proxy /api/* 127.0.0.1:8082
}
